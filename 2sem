#pragma once
#include "cstdlib"
#include "Student.h"


 
//пузырьком по номеру группы
template <class T>
void booblesort(T* a, int n) {
	int flag = 1;
	T h;
	while (flag) {
		flag = 0;
		for (int i = 1; i < n; i++) {
			if (a[i - 1].groupNumber > a[i].groupNumber) { 
				h = a[i - 1];
				a[i - 1] = a[i];
				a[i] = h;
				flag = 1;

			}
		}
	}
}
//вставками по номеру группы
template <class T>
void insert(T* a, int n) {
	T t;
	for (int i = 1; i < n; i++) {
		t = a[i];
		int j = i - 1;
		while (j >= 0 && a[j].groupNumber > t.groupNumber) {
			a[j + 1] = a[j];
			j--;
		}
		a[j + 1] = t;
	}
}

//сортировка выбором по номеру группы
template <class T>
void select(T* a, int n) {
	int min;
	T t;
	for (int i = 0; i < n - 1; i++) {
		min = i;
		for (int j = i + 1; j < n; j++) {
			if (a[j].groupNumber < a[min].groupNumber)
				min = j;
		}
		if (min != i) {
			t = a[i];
			a[i] = a[min];
			a[min] = t;
		}
	}
}

//сортировка шелла по номмеру группы
template <class T>
void shell(T* a, int n) {
	int steps[5] = { 121, 40, 13, 4, 1 };
	int j;
	T t;
	for (int k = 0; k < 5; k++) {
		int step = steps[k];
		for (int i = step; i < n; i++) {
			t = a[i];
			for (j = i - step; j >= 0 && t.groupNumber < a[j].groupNumber; j -= step) {
				a[j + step] = a[j];
			}
			a[j + step] = t;
		}
	}
}

int compStudentByGroup(const void* a, const void* b) {
    Student* pa = (Student*)a;
    Student* pb = (Student*)b;
    return pa->groupNumber - pb->groupNumber;
}

template <class T>
void stdQsort(T* a, int n) {
	qsort(a, n, sizeof(T), compStudentByGroup);
}






